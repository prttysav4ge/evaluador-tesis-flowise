# ============================================
# POC: Evaluador de Tesis - Variables de Entorno
# Copia este archivo como .env y completa los valores
# ============================================

# ----- SERVIDOR -----
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ----- FLOWISE -----
# Los agentes corren en Flowise (con Groq configurado allí).
# La API key de Groq se configura directamente en cada nodo dentro de Flowise,
# NO aquí en el .env.

# Usa Flowise para los agentes (true) o Python directo (false)
USE_FLOWISE=true

# URL del servidor Flowise (por defecto puerto 3000)
FLOWISE_URL=http://localhost:3000
# ID del Chatflow: copiarlo desde la URL del chatflow en la UI de Flowise
# Ejemplo: http://localhost:3000/chatflows/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
FLOWISE_CHATFLOW_ID=8ef396a1-4ae8-45b7-93cb-5b449e928854
# API Key de Flowise (opcional, solo si habilitaste autenticación en Flowise)
FLOWISE_API_KEY=

# ----- PROVEEDOR LLM (modo Python puro — solo aplica si USE_FLOWISE=false) -----
# Si USE_FLOWISE=true, estas variables son ignoradas.
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ----- EMBEDDINGS -----
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# ----- CHROMADB -----
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=academic_thesis

# ----- RAG -----
# Número de chunks a recuperar por consulta
TOP_K=5

# ----- CHUNKING -----
CHUNK_SIZE=800
CHUNK_OVERLAP=150
